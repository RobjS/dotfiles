{
    "editor.fontSize": 14,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
      },
    "editor.wordBasedSuggestions": "matchingDocuments",
    "php.suggest.basic": false,
    "workbench.colorTheme": "Solarized Dark",
    "intelephense.stubs": [
